@{
    ViewData["Title"] = "Factura";
}

<div class="container my-5 d-flex justify-content-center">
    <div class="p-4 shadow rounded bg-white" style="max-width: 520px; width:100%;" id="facturaWrap">

        <h2 class="text-center mb-3">Peluditos & Co</h2>
        <p class="text-center text-muted mb-4">Factura / Ticket</p>

        <hr>

        <div id="facturaItems"></div>

        <hr>

        <div class="d-flex justify-content-between fw-bold fs-5">
            <span>Total</span>
            <span id="facturaTotal">₡0</span>
        </div>

        <div class="text-center text-muted mt-2" id="orderCode" style="display:none;"></div>

        <hr>

        <p class="text-center fw-semibold mt-4">
            🐶 Presente esta factura en tienda y pague físicamente
            para retirar su pedido.
        </p>

        <div class="text-center mt-4">
            <a href="/Home/Catalogo" class="btn btn-outline-secondary">
                Seguir comprando
            </a>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function getCart() {
        return JSON.parse(localStorage.getItem("cart") || "[]");
    }

    function formatCRC(value) {
        return "₡" + value.toLocaleString();
    }

    async function guardarCompraEnFirestore(user, cart, total) {
        const db = firebase.firestore();

        // items listos para guardarse
        const items = cart.map(p => ({
            id: String(p.id),
            nombre: p.nombre,
            precio: Number(p.precio),
            cantidad: Number(p.cantidad),
            subtotal: Number(p.precio) * Number(p.cantidad),
            imagen: p.imagen || null
        }));

        // Documento de compra
        const compra = {
            uid: user.uid,
            email: user.email || "desconocido",
            total: total,
            items: items,
            createdAt: firebase.firestore.FieldValue.serverTimestamp()
        };

        const docRef = await db.collection("compras").add(compra);
        return docRef.id;
    }

    document.addEventListener("DOMContentLoaded", () => {
        const wrap = document.getElementById("facturaWrap");
        const itemsEl = document.getElementById("facturaItems");
        const totalEl = document.getElementById("facturaTotal");
        const codeEl = document.getElementById("orderCode");

        firebase.auth().onAuthStateChanged(async (user) => {
            if (!user) {
                requireLogin("Inicia sesión para continuar con la factura.");
                wrap.style.display = "none";
                return;
            }

            const cart = getCart();

            if (cart.length === 0) {
                itemsEl.innerHTML = `
                    <div class="alert alert-warning text-center">
                        No hay productos para facturar.
                    </div>`;
                totalEl.textContent = formatCRC(0);
                return;
            }

            // Render factura
            let total = 0;
            itemsEl.innerHTML = "";

            cart.forEach(p => {
                const subtotal = Number(p.precio) * Number(p.cantidad);
                total += subtotal;

                itemsEl.innerHTML += `
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            ${p.nombre} <span class="text-muted">x${p.cantidad}</span>
                        </div>
                        <div>${formatCRC(subtotal)}</div>
                    </div>
                `;
            });

            totalEl.textContent = formatCRC(total);

            // ✅ Evitar duplicar compra si recarga la página
            const alreadySaved = sessionStorage.getItem("order_saved");
            if (!alreadySaved) {
                try {
                    const orderId = await guardarCompraEnFirestore(user, cart, total);
                    sessionStorage.setItem("order_saved", "1");
                    sessionStorage.setItem("last_order_id", orderId);

                    codeEl.style.display = "block";
                    codeEl.textContent = `Código de compra: ${orderId}`;
                } catch (e) {
                    console.error("Error guardando compra:", e);
                    // No vaciamos carrito si no se guardó
                    alert("No se pudo registrar la compra. Revisa tu conexión/reglas de Firestore.");
                    return;
                }

                // ✅ Vacía carrito solo si se guardó bien
                localStorage.removeItem("cart");
            } else {
                // Si ya estaba guardada (refresh), solo muestra el código si existe
                const lastId = sessionStorage.getItem("last_order_id");
                if (lastId) {
                    codeEl.style.display = "block";
                    codeEl.textContent = `Código de compra: ${lastId}`;
                }
            }
        });
    });
</script>
}