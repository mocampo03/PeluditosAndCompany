@{
    ViewData["Title"] = "Detalle de compra";
    var id = (string)(ViewBag.CompraId ?? "");
}

<div class="container my-5">
    <h1 class="text-center mb-4">Detalle de compra</h1>

    <div id="detalleWrap"></div>

    <div class="text-center mt-4">
        <a href="/Admin/Compras" class="btn btn-outline-secondary">⬅ Volver</a>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", () => {
    const wrap = document.getElementById("detalleWrap");
    const compraId = "@id";

    firebase.auth().onAuthStateChanged(async (user) => {
        if (!user) {
            requireLogin("Inicia sesión para ver el detalle.");
            wrap.innerHTML = "";
            return;
        }
        if (user.uid !== ADMIN_UID) {
            wrap.innerHTML = `<div class="alert alert-danger text-center">Acceso solo para administrador.</div>`;
            return;
        }

        if (!compraId) {
            wrap.innerHTML = `<div class="alert alert-warning text-center">Compra no encontrada.</div>`;
            return;
        }

        try {
            const db = firebase.firestore();
            const docSnap = await db.collection("compras").doc(compraId).get();

            if (!docSnap.exists) {
                wrap.innerHTML = `<div class="alert alert-warning text-center">Compra no encontrada.</div>`;
                return;
            }

            const c = docSnap.data();
            const fecha = c.createdAt && c.createdAt.toDate ? c.createdAt.toDate().toLocaleString() : "—";
            const email = c.email || c.uid || "—";
            const total = c.total ?? 0;
            const items = Array.isArray(c.items) ? c.items : [];

            let html = `
              <div class="card shadow-sm">
                <div class="card-body">
                  <div class="d-flex justify-content-between flex-wrap gap-2">
                    <div><strong>Compra:</strong> ${compraId}</div>
                    <div><strong>Fecha:</strong> ${fecha}</div>
                    <div><strong>Usuario:</strong> ${email}</div>
                  </div>

                  <hr/>

                  <div class="table-responsive">
                    <table class="table align-middle">
                      <thead>
                        <tr>
                          <th>Artículo</th>
                          <th class="text-center">Cantidad</th>
                          <th class="text-end">Precio</th>
                          <th class="text-end">Subtotal</th>
                        </tr>
                      </thead>
                      <tbody>
            `;

            items.forEach(it => {
                const nombre = it.nombre || "—";
                const cantidad = Number(it.cantidad || 0);
                const precio = Number(it.precio || 0);
                const subtotal = Number(it.subtotal || (precio * cantidad));

                html += `
                  <tr>
                    <td>${nombre}</td>
                    <td class="text-center">${cantidad}</td>
                    <td class="text-end">₡${precio.toLocaleString()}</td>
                    <td class="text-end fw-bold">₡${subtotal.toLocaleString()}</td>
                  </tr>
                `;
            });

            html += `
                      </tbody>
                    </table>
                  </div>

                  <div class="text-end fs-5 fw-bold mt-3">
                    Total: ₡${Number(total).toLocaleString()}
                  </div>
                </div>
              </div>
            `;

            wrap.innerHTML = html;

        } catch (e) {
            console.error(e);
            wrap.innerHTML = `<div class="alert alert-danger text-center">Error cargando detalle. Revisa consola.</div>`;
        }
    });
});
</script>
}